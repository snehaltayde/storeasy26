# Copy to .env.local and fill in. .env.local is gitignored.

# ---- Shopify (Dev Dashboard app — post-Jan-2026 flow) ----
SHOPIFY_STORE_DOMAIN=beastlife.myshopify.com
SHOPIFY_API_VERSION=2025-10

# Dev Dashboard app client credentials. `pnpm shopify:token --write` exchanges
# these (client-credentials grant) for an Admin token, then mints a long-lived
# Storefront token into SHOPIFY_STOREFRONT_TOKEN below.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Storefront token used by the catalog sync (minted from the app above, or a
# Headless-channel public token). NOT the Admin token / client secret.
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# Public store domain for cart → Shopify checkout permalinks (customer-facing domain).
NEXT_PUBLIC_SHOPIFY_DOMAIN=beastlife.in

# ---- Database ----
# Local dev: a libSQL file. For Turso cloud (preferred + edge), set TURSO_DB_* —
# the app reads those first, then DATABASE_URL, then a local file.
DATABASE_URL=file:local.db
TURSO_DB_URL=
TURSO_DB_AUTH_TOKEN=

# ---- Typesense (optional) ----
# Until these are set, search falls back to a SQL query over the local catalog.
TYPESENSE_HOST=
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_ADMIN_API_KEY=

# ---- Razorpay (TEST mode) — dashboard.razorpay.com → Test Mode → API Keys ----
# Env-driven: test keys here/staging, BeastLife's live keys in prod once their
# KYC'd account is wired. The webhook secret is CHOSEN when creating the webhook
# (dashboard or API) — it is NOT the key secret. /api/razorpay/webhook verifies
# deliveries with it.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Shopify order push + ops (Session 12) ----
# The push uses SHOPIFY_STORE_DOMAIN + SHOPIFY_ADMIN_TOKEN above (write_orders /
# write_draft_orders scopes). These knobs tune the retry queue; defaults shown.
# CRON_SECRET guards /api/jobs/sync-shopify (Vercel cron sends it as a Bearer
# token automatically). ALERT_WEBHOOK_URL receives dead-letter/mismatch alerts
# (Slack-compatible JSON: { text, subject, detail, at }).
CRON_SECRET=
ALERT_WEBHOOK_URL=
# SHOPIFY_SYNC_MAX_ATTEMPTS=5
# SHOPIFY_SYNC_BACKOFF_MS=60000
# SHOPIFY_SYNC_STALE_MS=600000

# ---- First-party event pipeline (Session 14) ----
# Identity cookies (_fp_cid/_fbp/_fbc/_fp_gclid) are host-only by default. When
# the app runs on a BeastLife subdomain (e.g. shop.beastlife.in), set
# COOKIE_DOMAIN=.beastlife.in so identity spans www/shop. Events are stored
# before forwarding; without GA4/Meta creds below the pipeline runs store-only.
COOKIE_DOMAIN=
# EVENTS_MAX_ATTEMPTS=8
# EVENTS_BACKOFF_MS=60000
# Which names relay to GA4 MP (default: purchase — the only GA4-deduped event;
# browser gtag owns the rest so nothing double-counts). "all" for QA/backfill.
# GA4_MP_EVENTS=purchase
# GA4_DEBUG_MODE=1   # adds debug_mode to MP relays → GA4 DebugView (QA only)

# ---- Tracking (Session 9) — GA4 Measurement Protocol + Meta Conversions API ----
# GA4: Admin → Data Streams → web stream → Measurement ID (G-XXXX), then
#   "Measurement Protocol API secrets" → Create
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
GA4_API_SECRET=
# Meta: Events Manager → dataset (pixel) → Settings → Dataset ID; Conversions API
#   → generate access token; Test Events tab → test code (TESTxxxxx)
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=
# META_API_VERSION=v21.0   # optional

# ---- Site (Session 16) ----
# Canonical origin for SEO metadata, sitemap, JSON-LD (per environment).
NEXT_PUBLIC_SITE_URL=

# ---- Hardening (Session 17) ----
# Rate limits are per-minute per-ip, in-memory per instance. Tune a route with
# RATE_LIMIT_<NAME>=n (checkout/track/search/cart/errors); disable locally for
# load scripts with RATE_LIMIT_DISABLED=1. Error alerts throttle per
# fingerprint via ERRORS_ALERT_EVERY_MS (default 1h).
# RATE_LIMIT_DISABLED=
# RATE_LIMIT_CHECKOUT=10
# ERRORS_ALERT_EVERY_MS=3600000
